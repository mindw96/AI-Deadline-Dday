{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/dday/conferences.schema.json",
  "title": "Dday Conference Data",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "fullName",
      "year",
      "field",
      "location",
      "websiteUrl",
      "sourceUrl",
      "sourceCheckedAt",
      "timezone",
      "deadlines"
    ],
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "name": { "type": "string", "minLength": 1 },
      "fullName": { "type": "string", "minLength": 1 },
      "year": { "type": "integer", "minimum": 2000 },
      "field": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "minItems": 1
      },
      "location": { "type": "string", "minLength": 1 },
      "websiteUrl": { "type": "string", "format": "uri" },
      "sourceUrl": { "type": "string", "format": "uri" },
      "sourceCheckedAt": { "type": "string", "format": "date" },
      "timezone": { "type": "string", "minLength": 1 },
      "deadlines": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": [
            "id",
            "label",
            "date",
            "timezone",
            "type",
            "isPrimary"
          ],
          "properties": {
            "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
            "label": { "type": "string", "minLength": 1 },
            "date": { "type": "string", "format": "date" },
            "time": {
              "anyOf": [
                { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
                { "type": "null" }
              ]
            },
            "timezone": { "type": "string", "minLength": 1 },
            "type": {
              "type": "string",
              "enum": [
                "abstract",
                "submission",
                "supplementary",
                "notification",
                "camera-ready",
                "conference-start",
                "conference-end"
              ]
            },
            "isPrimary": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
